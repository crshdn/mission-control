{
  "name": "mission-control",
  "version": "2.4.0",
  "private": true,
  "scripts": {
    "dev": "./scripts/run-with-project-node.sh node ./node_modules/next/dist/bin/next dev --turbo -p ${PORT:-4000}",
    "build": "./scripts/run-with-project-node.sh node ./node_modules/next/dist/bin/next build",
    "start": "./scripts/run-with-project-node.sh node ./node_modules/next/dist/bin/next start -p ${PORT:-4000}",
    "lint": "./scripts/run-with-project-node.sh node ./node_modules/next/dist/bin/next lint",
    "typecheck": "./scripts/run-with-project-node.sh node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "mkdir -p .tmp && rm -f .tmp/mission-control-test.db* && NODE_ENV=test DATABASE_PATH=.tmp/mission-control-test.db ./scripts/run-with-project-node.sh node ./node_modules/tsx/dist/cli.mjs --test --test-concurrency=1 src/**/*.test.ts",
    "test:smoke": "./scripts/run-with-project-node.sh node --import tsx scripts/smoke-autopilot.ts",
    "test:pr-validation": "./scripts/run-with-project-node.sh node --import tsx scripts/validate-disposable-pr.ts",
    "test:self-improvement": "./scripts/run-with-project-node.sh node --import tsx scripts/verify-self-improvement.ts",
    "test:automation-verification": "./scripts/run-with-project-node.sh node --import tsx scripts/verify-automation-rollbacks.ts",
    "cutline:telegram": "./scripts/run-with-project-node.sh node --import tsx scripts/cutline-telegram-intake.ts",
    "db:seed": "./scripts/run-with-project-node.sh node --import tsx src/lib/db/seed.ts",
    "db:backup": "sqlite3 mission-control.db 'PRAGMA wal_checkpoint(TRUNCATE);' && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@hello-pangea/dnd": "^17.0.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "lucide-react": "^0.468.0",
    "next": "14.2.21",
    "playwright": "^1.58.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "source-map-js": "^1.2.1",
    "uuid": "^11.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^20.17.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
